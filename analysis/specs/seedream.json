                          "fast"
                        ],
                        "description": "Seedream Images Optimize Prompt Options Mode"
                      }
                    },
                    "description": "Seedream Images Optimize Prompt Options"
                  },
                  "callback_url": {
                    "type": "string",
                    "description": "Seedream Images Callback Url"
                  },
                  "async": {
