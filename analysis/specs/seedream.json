                    "type": "number",
                    "format": "float",
                    "description": "Seedream Images Guidance Scale"
                  },
                  "response_format": {
                    "type": "string",
                    "description": "Seedream Images Response Format"
                  },
                  "watermark": {
                    "type": "boolean",
                    "description": "Seedream Images Watermark"
                  },
                  "output_format": {
                    "type": "string",
                    "enum": [
