{
  "name": "@acedatacloud/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for AceDataCloud — AI-powered data services",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "test": "jest --forceExit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "dotenv": "^17.3.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  }
}
